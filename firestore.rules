rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user has an admin role in the users collection
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for users collection
    match /users/{userId} {
      allow create: if true; // Let students register
      allow read, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Rules for educational content (Lectures, Notes, Past Papers, MCQs, Quizzes, Mock Tests)
    match /lectures/{lectureId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /pastpapers/{paperId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /mocktests/{testId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /expected_mcqs/{mcqId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // History / Scores collection (for tracking mock test scores)
    match /results/{resultId} {
      allow create, read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
